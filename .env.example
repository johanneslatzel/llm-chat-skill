# LLM Chat Skill — Configuration (example reference)
# Copy to .env and fill in your values.

# --- Skill tools ---
LLM_CHAT_SKILL_DIR=                             # Directory containing skill subdirectories (default: '')
LLM_CHAT_SKILL_WARNINGS=                        # Warning mode: 'silent', 'log', or 'error' (default: 'silent')

# --- Length bounds for skill fields ---
LLM_CHAT_SKILL_NAME_MIN_LENGTH=                 # Min skill name length (default: 5)
LLM_CHAT_SKILL_NAME_MAX_LENGTH=                 # Max skill name length (default: 60)
LLM_CHAT_SKILL_DESCRIPTION_MIN_LENGTH=          # Min skill description length (default: 25)
LLM_CHAT_SKILL_DESCRIPTION_MAX_LENGTH=          # Max skill description length (default: 500)
LLM_CHAT_SKILL_BODY_MIN_LENGTH=                 # Min skill body length (default: 300)
LLM_CHAT_SKILL_BODY_MAX_LENGTH=                 # Max skill body length (default: 20000)

# --- Length bounds for resource fields ---
LLM_CHAT_RESOURCE_NAME_MIN_LENGTH=              # Min resource file name length (default: 5)
LLM_CHAT_RESOURCE_NAME_MAX_LENGTH=              # Max resource file name length (default: 60)
LLM_CHAT_RESOURCE_CONTENT_MIN_LENGTH=           # Min resource content length (default: 1)
LLM_CHAT_RESOURCE_CONTENT_MAX_LENGTH=           # Max resource content length (default: 10000)
